{
  "name": "stalio-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "pnpm habits:generate",
    "dev": "next dev",
    "prebuild": "pnpm habits:generate",
    "build": "next build",
    "start": "npx serve out",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "habits:generate": "tsx scripts/generate-habits.ts",
    "habits:check": "tsx scripts/check-habits.ts",
    "pages:deploy": "wrangler pages deploy out --project-name=stalio-web",
    "pages:dev": "wrangler pages dev out"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.26.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "csv-parse": "^5.6.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
