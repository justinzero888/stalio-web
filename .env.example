# ---------------------------------------------------------------------------
# Stalio Web — environment variables (Part 1: static site, no database)
# Copy to .env.local and fill in. NEVER commit real secrets.
# All build-time vars are NEXT_PUBLIC_* and inlined into the static export.
# See docs/plan/02_ACCOUNTS_AND_CONFIG.md
# ---------------------------------------------------------------------------

# --- Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"   # prod: https://stalio.app or https://stalio.orbacetech.com

# --- App store + deep link (from mobile team near launch — fallback used until then)
NEXT_PUBLIC_APP_STORE_URL=""        # iOS App Store listing
NEXT_PUBLIC_PLAY_STORE_URL=""       # Google Play listing
NEXT_PUBLIC_DEEPLINK_SCHEME="stalio"

# Deep-link well-known files live in public/.well-known/ — replace the
# REPLACE_* placeholders there with values from the mobile team (C1–C4).

# ---------------------------------------------------------------------------
# DEFERRED (opt-in) — not wired in Part 1 per docs/plan/SERVICES_RATIONALE.md
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ---------------------------------------------------------------------------
# PART 2 ONLY — not used by the static Part 1 site.
# A database (e.g. Supabase) + dynamic backend is introduced only if/when a
# self-hosted community is built. Current plan leans toward a Reddit community
# instead — see docs/plan/00_PROGRAM_OVERVIEW.md.
# ---------------------------------------------------------------------------
# DATABASE_URL=""
# CLERK_SECRET_KEY=""
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
# RESEND_API_KEY=""
